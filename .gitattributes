# Normalize all text files automatically
* text=auto

# --- PowerShell (cross-platform friendly) ---
*.ps1  text
*.psm1 text
*.psd1 text

# --- Config / data ---
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# --- Markdown / docs ---
*.md   text eol=lf
*.txt  text

# --- Scripts ---
*.sh   text eol=lf

# --- Windows-specific ---
*.bat  text eol=crlf
*.cmd  text eol=crlf

# --- Binary files (never modify) ---
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.exe  binary
*.dll  binary
*.pdf  binary